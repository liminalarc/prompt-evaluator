# Copy to .env and fill in. docker compose reads .env automatically.

# Postgres (compose db service + api connection string)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=prompteval

# Claude API key — used by eval-runner for LLM-judge scoring + synthetic fixtures.
# Not needed for the walking-skeleton echo path, but the wiring exists.
ANTHROPIC_API_KEY=
