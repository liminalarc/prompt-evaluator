# Copy to .env and fill in. docker compose reads .env automatically.

# Postgres (compose db service + api connection string)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=litmusai

# Model-provider credentials for the eval-runner. A provider is only usable when its key is
# set; requesting a model whose provider has no key fails clearly (HTTP 400). Claude is the
# default judge/generator and subject provider.
#   - claude-*   -> ANTHROPIC_API_KEY  (default; required for the LLM-judge + synthetic path)
#   - gpt-* / o* -> OPENAI_API_KEY      (optional; only needed to evaluate OpenAI models)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
